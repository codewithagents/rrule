{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "ignorePatterns": ["packages/*/dist/**"],
  "ignoreUnresolvedImports": [],
  "ignoreDependencies": [],
  "rules": {
    "unused-files": "warn",
    "unused-exports": "warn",
    "unused-types": "off"
  },
  "health": {
    "maxCyclomatic": 30,
    "maxCognitive": 30
  }
}
